# ──────────────────────────────────────────────────────────────────
# IA_Orquestador — .gitignore
# ──────────────────────────────────────────────────────────────────

# Compiled binaries
bin/
dist/

# SQLite databases and WAL files
*.db
*.db-shm
*.db-wal

# Test coverage
coverage.out
coverage.html

# Secrets and local config
.env
.env.*
!.env.example
configs/*.yaml
!configs/*.example.yaml

# Local MCP client config (contains server IPs / tokens)
.mcp.json
!.mcp.json.example

# Log files
*.log

# OS artifacts
.DS_Store
Thumbs.db

# Editor artifacts
.vscode/settings.json
.vscode/launch.json
.idea/
*.swp
*.swo

# Go toolchain
vendor/

# Kubernetes secrets (never commit — use kubectl apply out-of-band)
deploy/kubernetes/secret.yaml
